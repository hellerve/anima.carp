(load "anima.carp")
(use Anima)

(def size 800)
(def margin 100)

(defn setup [cr]
  (framerate 1))

(defn draw [cr]
  (do
    (background cr 20)
    (stroke-color 200)
    (for [i 0 300]
      (let [x (random-between margin (- size margin))
            y (random-between margin (- size margin))]
        (line cr (Double.from-int x) (Double.from-int y)
                 (Double.from-int x) (Double.from-int x))))))

(defsketch "Whispering Drink" size size
  setup
  draw)
